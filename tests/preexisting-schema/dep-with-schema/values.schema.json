{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "port": {
      "type": "integer",
      "description": "The port to listen on",
      "minimum": 1,
      "maximum": 65535
    },
    "host": {
      "type": "string",
      "description": "The hostname to bind to",
      "format": "hostname",
      "x-custom-annotation": "preserve-me"
    }
  },
  "required": [
    "host",
    "port"
  ]
}
